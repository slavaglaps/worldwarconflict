# Скопируй в .env и заполни. На Colyseus Cloud переменные задаются в дашборде (Settings → Env).

# Порт (локально; Colyseus Cloud задаёт сам)
PORT=2567

# Секрет подписи JWT — ОБЯЗАТЕЛЬНО смени на длинную случайную строку в проде
JWT_SECRET=change-me-to-a-long-random-secret

# Файловый стор аккаунтов (dev/тесты). Используется, ПОКА не задан DATABASE_URL.
DB_FILE=./data/db.json

# ── Postgres (прод) ── Если задан DATABASE_URL — стор сам переключается с файла на Postgres
# (таблицы users/matches создаются автоматически при старте; код вызова не меняется).
# Supabase: Dashboard → Project Settings → Database → Connection string → URI.
# Бери POOLER-строку (порт 6543) для serverless/Cloud:
# DATABASE_URL=postgres://postgres.<ref>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:6543/postgres
# PG_POOL_MAX=10           # размер пула соединений (по умолчанию 10)
# PGSSL=disable            # ТОЛЬКО для локального Postgres без SSL (Supabase/Neon — НЕ ставить)

# Redis для мультипроцесса при self-host (Hetzner/DO). На Colyseus Cloud НЕ нужен — масштаб их.
# REDIS_URL=redis://localhost:6379
